rules_version = '2';

// StreakSync Firestore Security Rules
// Deploy: firebase deploy --only firestore:rules
// Last security audit: 2026-03-13

service cloud.firestore {
  match /databases/{database}/documents {
    function hasRequiredAndOnly(required, optional) {
      let allAllowed = required.concat(optional);
      return request.resource.data.keys().hasAll(required)
        && request.resource.data.keys().hasOnly(allAllowed);
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Max string sizes to prevent document-size DoS
    function isShortString(val) {
      return val is string && val.size() > 0 && val.size() <= 200;
    }

    // Check if two users have an accepted friendship via the friendships collection.
    // Replaces the old 'friends' array approach which required cross-user writes
    // that violated security rules (only owner can update their own profile).
    // Cost: 1 exists() + 1 get() per evaluation (within Firestore's 10-read budget).
    function areFriends(uid1, uid2) {
      let path1 = /databases/$(database)/documents/friendships/$(uid1 + '_' + uid2);
      let path2 = /databases/$(database)/documents/friendships/$(uid2 + '_' + uid1);
      return (exists(path1) && get(path1).data.status == 'accepted')
          || (exists(path2) && get(path2).data.status == 'accepted');
    }

    // --- Users ---
    // Full profile readable by the user themselves or accepted friends.
    // Friend status is checked via the friendships collection (not a denormalized array).
    match /users/{userId} {
      allow read: if isSignedIn()
        && (request.auth.uid == userId
            || areFriends(request.auth.uid, userId));

      allow create: if isSignedIn()
        && request.auth.uid == userId
        && hasRequiredAndOnly(
          ['displayName', 'createdAt', 'updatedAt'],
          ['authProvider', 'photoURL', 'friendCode', 'friends']
        )
        && isShortString(request.resource.data.displayName)
        && (!('friends' in request.resource.data)
            || (request.resource.data.friends is list
                && request.resource.data.friends.size() <= 500));

      allow update: if isSignedIn()
        && request.auth.uid == userId
        && hasRequiredAndOnly(
          ['displayName', 'createdAt', 'updatedAt'],
          ['authProvider', 'photoURL', 'friendCode', 'friends']
        )
        && isShortString(request.resource.data.displayName)
        && (!('friends' in request.resource.data)
            || (request.resource.data.friends is list
                && request.resource.data.friends.size() <= 500));

      // Owner can delete their own profile (account deletion flow)
      allow delete: if isSignedIn() && request.auth.uid == userId;

      // --- Game Results (private per-user) ---
      match /gameResults/{resultId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow delete: if isSignedIn() && request.auth.uid == userId;
        allow create, update: if isSignedIn()
          && request.auth.uid == userId
          && hasRequiredAndOnly(
            ['gameId', 'gameName', 'date', 'maxAttempts', 'completed', 'sharedText', 'parsedData', 'lastModified'],
            ['score']
          )
          && isShortString(request.resource.data.gameId)
          && isShortString(request.resource.data.gameName)
          && request.resource.data.maxAttempts is int
          && request.resource.data.completed is bool
          && request.resource.data.sharedText is string
          && request.resource.data.sharedText.size() <= 2500
          && request.resource.data.parsedData is map
          && (!('score' in request.resource.data) || request.resource.data.score is int);
      }

      // --- Sync data (achievements, private per-user) ---
      match /sync/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- Friend Codes ---
    // Minimal lookup collection: { userId, displayName }
    // Readable by any authenticated user (needed for friend code entry).
    // Separated create/update/delete to prevent hijacking (C1 fix).
    match /friendCodes/{code} {
      allow read: if isSignedIn();

      // Only creator can mint a new code
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && hasRequiredAndOnly(['userId', 'displayName'], [])
        && request.resource.data.userId is string
        && isShortString(request.resource.data.displayName);

      // Only the code owner can update their code's display name
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && hasRequiredAndOnly(['userId', 'displayName'], [])
        && request.resource.data.userId is string
        && isShortString(request.resource.data.displayName);

      // Only the code owner can delete their code
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // --- Scores ---
    // Leaderboard scores. Each score document includes an `allowedReaders`
    // array set at publish time to [publisher] + [publisher's friends].
    // Reads are restricted to users in that array.
    match /scores/{scoreId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.allowedReaders;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && hasRequiredAndOnly(
          ['userId', 'gameId', 'dateInt', 'gameName', 'completed', 'allowedReaders'],
          ['score', 'maxAttempts', 'currentStreak', 'publishedAt']
        )
        && isShortString(request.resource.data.userId)
        && isShortString(request.resource.data.gameId)
        && request.resource.data.dateInt is int
        && request.resource.data.completed is bool
        && isShortString(request.resource.data.gameName)
        && request.resource.data.allowedReaders is list
        && request.resource.data.allowedReaders.size() <= 500
        && request.auth.uid in request.resource.data.allowedReaders
        && (!('score' in request.resource.data) || request.resource.data.score is int)
        && (!('maxAttempts' in request.resource.data) || request.resource.data.maxAttempts is int)
        && (!('currentStreak' in request.resource.data) || request.resource.data.currentStreak is int);

      // Update requires ownership of the existing doc to prevent overwriting
      // another user's score by supplying a different userId in the new data.
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && hasRequiredAndOnly(
          ['userId', 'gameId', 'dateInt', 'gameName', 'completed', 'allowedReaders'],
          ['score', 'maxAttempts', 'currentStreak', 'publishedAt']
        )
        && isShortString(request.resource.data.userId)
        && isShortString(request.resource.data.gameId)
        && request.resource.data.dateInt is int
        && request.resource.data.completed is bool
        && isShortString(request.resource.data.gameName)
        && request.resource.data.allowedReaders is list
        && request.resource.data.allowedReaders.size() <= 500
        && request.auth.uid in request.resource.data.allowedReaders
        && (!('score' in request.resource.data) || request.resource.data.score is int)
        && (!('maxAttempts' in request.resource.data) || request.resource.data.maxAttempts is int)
        && (!('currentStreak' in request.resource.data) || request.resource.data.currentStreak is int);

      // Owner can delete their own scores (account deletion flow)
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // --- Friendships ---
    match /friendships/{friendshipId} {
      // Read: either party
      allow read: if isSignedIn()
        && (resource.data.userId1 == request.auth.uid
            || resource.data.userId2 == request.auth.uid);

      // Create: sender must be userId1, status must start as pending,
      // required fields present, sender != recipient.
      // senderDisplayName is size-limited.
      allow create: if isSignedIn()
        && request.resource.data.userId1 == request.auth.uid
        && request.resource.data.userId1 != request.resource.data.userId2
        && request.resource.data.status == 'pending'
        && hasRequiredAndOnly(['userId1', 'userId2', 'status', 'createdAt'], ['senderDisplayName'])
        && request.resource.data.userId1 is string
        && request.resource.data.userId2 is string
        && (!('senderDisplayName' in request.resource.data)
            || isShortString(request.resource.data.senderDisplayName));

      // Update: ONLY the recipient (userId2) can accept,
      // and ONLY the status field may change (to 'accepted').
      // userId1, userId2 are immutable.
      allow update: if isSignedIn()
        && resource.data.userId2 == request.auth.uid
        && request.resource.data.status == 'accepted'
        && resource.data.status == 'pending'
        && request.resource.data.userId1 == resource.data.userId1
        && request.resource.data.userId2 == resource.data.userId2;

      // Delete: either party can remove the friendship
      allow delete: if isSignedIn()
        && (resource.data.userId1 == request.auth.uid
            || resource.data.userId2 == request.auth.uid);
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
